# ── Tier 1: LLM chain (comma-separated, tried left-to-right) ──────────────────
# Swap any model string supported by LiteLLM:
#   anthropic/claude-haiku-4-5-20251001
#   openai/gpt-4o-mini
#   gemini/gemini-2.0-flash
#   groq/llama-3.3-70b-versatile        (free tier – console.groq.com)
#   cerebras/llama-4-scout-17b-16e-instruct  (free tier – inference.cerebras.ai)
#   ollama/qwen2.5:14b                   (local – run `ollama serve` first)
LLM_MODELS=anthropic/claude-haiku-4-5-20251001,groq/llama-3.3-70b-versatile

# ── Provider API keys (leave blank if not using that provider) ─────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
CEREBRAS_API_KEY=...
# Ollama needs no key — just `ollama serve` running locally

# ── Tier 2: non-LLM open-source extractors ────────────────────────────────────
ENABLE_INVOICE2DATA=true
ENABLE_SPACY=true
ENABLE_BERT_NER=false   # set true to download ~400 MB model on first run

# ── Tuning ────────────────────────────────────────────────────────────────────
MAX_ATTEMPTS=3          # max extraction+validation retries before NEEDS_REVIEW
LLM_TIMEOUT=30          # seconds before a single LLM call times out
TOLERANCE=0.01          # arithmetic tolerance in currency units (default: 1 cent)
DATABASE_URL=./invoices.db
